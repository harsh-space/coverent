{
  "version": 2,
  "builds": [
    {
      "src": "frontend/rider-pwa/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/rider-pwa/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "frontend/rider-pwa/index.html"
    }
  ]
}
